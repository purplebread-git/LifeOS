APP_ENV=development
APP_DEBUG=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT=60.0

DATABASE_URL=sqlite+aiosqlite:///./lifeos.db

# storage: memory | sqlite
MEMORY_BACKEND=sqlite
# search: substring | semantic (semantic работает поверх sqlite)
MEMORY_SEARCH_MODE=substring
# порог cosine-близости для semantic-ранжирования (0.0..1.0): ниже — отсекается
MEMORY_SIMILARITY_THRESHOLD=0.25

# storage знаний: memory | sqlite
KNOWLEDGE_BACKEND=sqlite